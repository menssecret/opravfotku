# Zkopíruj tenhle soubor jako `.env.local` a doplň svůj token.
# .env.local je v .gitignore, takže se nedostane do gitu.

# Získej zdarma na https://replicate.com/account/api-tokens
# Bez kreditky. Free tier dává několik runů zdarma na "Try for Free" modelech
# (včetně flux-kontext-pro, který používáme).
REPLICATE_API_TOKEN=
